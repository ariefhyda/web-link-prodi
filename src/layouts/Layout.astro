---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = "Sarjana Terapan Teknik Informatika - Universitas Harkat Negeri" } = Astro.props;
---

<!DOCTYPE html>
<html class="light" lang="id">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>{title}</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@600;700&amp;family=Inter:wght@400;500;600&amp;display=swap"
        rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet">
    <link rel="icon" type="image/png" href="/assets/media/logo.png" />
</head>
<body class="bg-surface text-on-surface min-h-screen flex flex-col items-center">
    <slot />
</body>
</html>
